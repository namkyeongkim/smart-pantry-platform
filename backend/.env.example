# Database Connection
# IMPORTANT: Ask the host (Sam) for the actual IP address if connecting remotely.
# For local development on the same machine: localhost
# For remote connection: 192.168.x.x (Host's IP)
DB_USER=pantry_user
DB_PASSWORD=pantry_password
DB_HOST=localhost
DB_NAME=pantry_db
DB_PORT=5432

# Spoonacular API Key
# Get this from https://spoonacular.com/food-api
SPOONACULAR_API_KEY=YOUR_API_KEY_HERE
