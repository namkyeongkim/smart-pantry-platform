# Base URL of backend server
# For local development:
# EXPO_PUBLIC_API_URL=http://localhost:3000
#
# If using ngrok:
# EXPO_PUBLIC_API_URL=https://your-ngrok-url.ngrok.io
#
# If using deployed backend:
# EXPO_PUBLIC_API_URL=https://your-production-url.com

EXPO_PUBLIC_API_URL=